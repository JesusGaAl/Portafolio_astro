<div class="dropdown dropdown-end" id="theme-selector">
  <div tabindex="0" role="button" class="btn btn-ghost m-1">
    <svg width="20" height="20" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block h-5 w-5 stroke-current md:h-6 md:w-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.172-1.172a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z"></path></svg>
    <span class="hidden md:inline">Theme</span>
  </div>
  
  <ul tabindex="0" class="dropdown-content z-[100] menu p-2 shadow-2xl bg-base-300 rounded-box w-60 mt-4 max-h-[70vh] flex flex-col flex-nowrap overflow-y-auto overflow-x-hidden border border-white/10">
    {
      ["light", "dark", "cupcake", "bumblebee", "emerald", "corporate", "synthwave", "retro", "cyberpunk", "valentine", "halloween", "garden", "forest", "aqua", "lofi", "pastel", "fantasy", "wireframe", "black", "luxury", "dracula", "cmyk", "autumn", "business", "acid", "lemonade", "night", "coffee", "winter"].map((theme) => (
        <li class="w-full mb-1">
          <button 
            class="theme-controller btn btn-sm btn-block justify-start gap-3 rounded-lg overflow-hidden flex flex-row nowrap" 
            data-theme={theme} 
            value={theme}
          >
            <span class="flex-grow text-left text-[10px] font-bold uppercase tracking-wider truncate">{theme}</span>
            
            <div class="flex flex-shrink-0 gap-1">
              <div class="bg-primary w-2 h-4 rounded-full" />
              <div class="bg-secondary w-2 h-4 rounded-full" />
              <div class="bg-accent w-2 h-4 rounded-full" />
              <div class="bg-neutral w-2 h-4 rounded-full" />
            </div>
          </button>
        </li>
      ))
    }
  </ul>
</div>