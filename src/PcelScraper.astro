---
// PcelScraper.astro
// Aquí va la lógica de JavaScript (Se ejecuta en el servidor durante la construcción/petición)

// Hacemos la petición GET a tu API viva en Render
const response = await fetch('https://apiscraperpcel.onrender.com/api/productos');
const productos = await response.json();
---

<section class="scraper-container">
  <h3>💻 Scraping en Tiempo Real (PCEL)</h3>
  <p class="subtitle">Datos extraídos mediante API en C# + PostgreSQL</p>

  {productos.length === 0 ? (
    <p class="empty-state">No hay datos en la base de datos. ¡Ejecuta el scraper!</p>
  ) : (
    <div class="productos-grid">
      {productos.map((producto) => (
        <article class="producto-card">
          <div class="producto-header">
            <h4>{producto.nombre}</h4>
          </div>
          <div class="producto-body">
            <span class="precio">{producto.precio}</span>
            <span class="fecha">
              Actualizado: {new Date(producto.fechaConsulta).toLocaleDateString()}
            </span>
          </div>
        </article>
      ))}
    </div>
  )}
</section>

<style>
  .scraper-container {
    background-color: #1a1a2e;
    color: #e2e8f0;
    padding: 2rem;
    border-radius: 12px;
    font-family: system-ui, sans-serif;
    margin: 2rem 0;
  }

  .subtitle {
    color: #94a3b8;
    margin-top: -10px;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .producto-card {
    background-color: #16213e;
    border: 1px solid #0f3460;
    border-radius: 8px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: transform 0.2s ease;
  }

  .producto-card:hover {
    transform: translateY(-5px);
  }

  h4 {
    margin: 0;
    font-size: 1rem;
    line-height: 1.4;
    color: #e94560; /* Un color de acento para el título */
  }

  .producto-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: auto; /* Empuja esto al fondo si el título es corto */
  }

  .precio {
    font-size: 1.8rem;
    font-weight: bold;
    color: #4ade80; /* Verde brillante para el precio */
  }

  .fecha {
    font-size: 0.8rem;
    color: #64748b;
  }
</style>